---
import "../styles/global.css";
import payload from "../../public/data/pages.json";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { renderMarkdown } from "../lib/markdown.js";

export function getStaticPaths() {
  return (payload.pages ?? []).map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const published = page.publishedAt ? new Date(page.publishedAt).toLocaleDateString("ja-JP") : "undated";
const bodyHtml = renderMarkdown(page.body, { imageBase: page.image });
const hasBody = page.body.trim().length > 0;
const directories = page.slug.split("/").slice(0, -1);
const breadcrumbs = directories.map((label, index) => ({
  label,
  href: "/" + directories.slice(0, index + 1).map(encodeURIComponent).join("/") + "/"
}));
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title} / pdnt-work</title>
  </head>
  <body>
    <main class="reader-shell" data-source={page.source}>
      <Breadcrumbs items={breadcrumbs} />
      <article class="reader-article">
        <header class="reader-header">
          <div class="reader-meta">
            <time class="reader-date" datetime={page.publishedAt ?? undefined}>{published}</time>
            <p class="reader-id">{page.id}</p>
          </div>
          <h1>{page.title}</h1>
        </header>
        {page.image && page.source === "typography" ? (
          <>
            <button class="reader-image-trigger" type="button" aria-label="画像を拡大表示">
              <img class="reader-cover" src={page.image} alt={page.imageAlt ?? ""} />
            </button>
            <dialog class="image-lightbox" aria-label={`${page.title} を拡大表示`}>
              <button class="image-lightbox-close" type="button" aria-label="閉じる">×</button>
              <img src={page.image} alt={page.imageAlt ?? ""} />
            </dialog>
          </>
        ) : null}
        {hasBody && <div class="reader-body" set:html={bodyHtml} />}
      </article>
    </main>
    {page.source === "typography" && (
      <script>
        const trigger = document.querySelector(".reader-image-trigger");
        const dialog = document.querySelector(".image-lightbox");
        const close = document.querySelector(".image-lightbox-close");

        trigger?.addEventListener("click", () => dialog?.showModal());
        close?.addEventListener("click", () => dialog?.close());
        dialog?.addEventListener("click", (event) => {
          if (event.target === dialog) dialog.close();
        });
      </script>
    )}
  </body>
</html>
