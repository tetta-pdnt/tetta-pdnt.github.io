---
import "../styles/global.css";
import { loadSiteData } from "../lib/site-data.js";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const { categories, items: allItems } = await loadSiteData();
const writingTags = categories.find((category) => category.key === "writing")?.children ?? [];
const items = allItems.filter((item) => writingTags.some((tag) => item.tags?.includes(tag)));

function itemHref(item) {
  return item.url;
}
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>writing / pdnt-work</title>
  </head>
  <body>
    <main class="reader-shell collection-shell">
      <Breadcrumbs items={[]} />
      <header class="collection-header">
        <h1>writing/</h1>
        <p class="reader-file">{items.length} items</p>
      </header>
      <section class="collection-grid" aria-label="writing items">
        {items.map((item) => (
          <a class="collection-card" href={itemHref(item)}>
            {item.image && <img src={item.image} alt="" loading="lazy" />}
            <div class="collection-card-body">
              <p class="collection-meta">{item.publishedAt ? new Date(item.publishedAt).toLocaleDateString("ja-JP") : "undated"}</p>
              <h2>{item.title}</h2>
              {item.summary && <p class="collection-summary">{item.summary}</p>}
              <div class="tag-row">{(item.tags ?? []).map((tag) => <span class="tag" data-tag={tag}>{tag}</span>)}</div>
            </div>
          </a>
        ))}
      </section>
    </main>
  </body>
</html>
